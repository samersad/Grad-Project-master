  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "let json = {};",
          "try { json = pm.response.json(); } catch (e) {}",
          "if (json.session?.access_token) pm.collectionVariables.set('accessToken', json.session.access_token);",
          "if (json.user?.id) pm.collectionVariables.set('userId', json.user.id);",
          "if (json.resetToken) pm.collectionVariables.set('resetToken', json.resetToken);",
          "if (json.id && pm.request.url.toString().includes('/apartments')) pm.collectionVariables.set('apartmentId', json.id);",
          "if (json.id && pm.request.url.toString().includes('/bookings')) pm.collectionVariables.set('bookingId', json.id);",
          "if (json.id && pm.request.url.toString().includes('/notifications')) pm.collectionVariables.set('notificationId', json.id);",
          "if (json.id && pm.request.url.toString().includes('/messages')) pm.collectionVariables.set('messageId', json.id);",
          "if (json.public_id) pm.collectionVariables.set('cloudinaryPublicId', json.public_id);"
        ]
      }
    }
  ],
